// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    String  @id @default(uuid())
  email String  @unique
  name  String
  password String
  avatar Int @default(1) // 大頭貼
  role String @default("user") // Default role is 'user'
  createdAt DateTime @default(now())
  createdList String[] @default([]) // 建立哪些店家資料
  favoriteList String[] @default([]) // 收藏哪些店家
  resetPasswordToken   String?   // 可為 null
  resetPasswordExpires DateTime? // token 過期時間
}

model ShopList {
  id      String  @id @default(uuid())
  name    String // 連鎖店會有多家同名分店，故不設 unique
  lat     Float // 緯度
  lng     Float // 經度
  address String
  city    String
  createdAt DateTime @default(now())
  createdBy String? // 哪個會員id建立這筆資料
  osmId   String? @unique // OSM 來源識別 (type/id)，供去重與重複匯入 upsert
  phone        String? // 電話
  openingHours String? // 營業時間 (OSM opening_hours 格式)
}